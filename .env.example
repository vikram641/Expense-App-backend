PORT=3000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/star_expense_tracker?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret
REFRESH_SECRET=your_refresh_secret
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d
NODE_ENV=development
# Firebase service account key JSON, as a single-line string (used for FCM push notifications).
# Local dev can instead drop the key file at src/config/serviceAccountKey.json and omit this.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
